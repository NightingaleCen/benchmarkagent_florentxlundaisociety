# Copy this file to `.env` (same directory) and fill in your values.
# `.env` is gitignored — never commit your real keys.
#
# The backend and `benchmarkrun` CLI both call python-dotenv's load_dotenv()
# at startup, so any var here ends up in the process environment.

# ---- Provider credentials ----
# Read directly by the official SDKs, not by our code.
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ---- Optional: custom API endpoints ----
# Point the SDKs at a proxy, gateway, or self-hosted endpoint.
# ANTHROPIC_BASE_URL=https://my-proxy.example.com/anthropic
# OPENAI_BASE_URL=https://my-proxy.example.com/v1

# ---- Backend settings ----
# Read by apps/backend/src/backend/config.py. All optional; sensible defaults.
# BMK_SESSIONS_ROOT=apps/backend/sessions
# BMK_ORCHESTRATOR_MODEL=claude-sonnet-4-6
# BMK_MAX_AGENT_ITERATIONS=20

# ---- Frontend ----
# Put this in apps/frontend/.env.local instead — Next.js loads it separately.
# NEXT_PUBLIC_BACKEND_URL=http://127.0.0.1:8000
